# ===========================================
# BOTKRIT — Environment Variables Template
# ===========================================
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Supabase

# Supabase Project URL (จากเมนู Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Anon key (public) — ใช้ฝั่ง browser/client ได้
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (secret) — ใช้เฉพาะฝั่ง server เท่านั้น (ห้ามขึ้นต้นด้วย NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# (เลือกใช้) URL ของเว็บไซต์ที่ deploy แล้ว ใช้ใน metadata/OG image
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# ช่องทางติดต่อ/ชำระเงิน (เฟสแรกเป็น static)
# ===========================================
NEXT_PUBLIC_LINE_URL=https://line.me/R/ti/p/@your-line-id
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/yourpage
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/yourusername
NEXT_PUBLIC_CONTACT_EMAIL=contact@botkrit.com

# ข้อมูลบัญชีรับโอน (โชว์ใน purchase modal)
NEXT_PUBLIC_BANK_NAME=ธนาคารกสิกรไทย
NEXT_PUBLIC_BANK_ACCOUNT_NAME=นาย ตัวอย่าง รับเงิน
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=123-4-56789-0
NEXT_PUBLIC_PROMPTPAY_QR_URL=/payment/promptpay-qr.png
